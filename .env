# Leave empty to use Vite proxy (recommended for local dev).
# Vite proxy points to Auth Proxy (port 8081), which forwards to Backend (port 8080).
# Set to a full URL only when pointing to a remote backend (e.g. staging).
# VITE_API_URL=http://localhost:8081

# Environment label shown in the Feedback widget and stored with every feedback entry.
# Values: development | staging | production
VITE_APP_ENV=development

# Shared LIFF ID — used for PNP link-token greeting flow (LON by Phone)
# Get from LINE Developers Console → LIFF app
VITE_SHARED_LIFF_ID=2009403660-gx1CeQ6A

# Direct backend URL for LIFF public endpoints (bypasses Vite proxy).
# Set to your ngrok/tunnel URL pointing directly at the backend (port 8097).
# Each developer sets their own tunnel URL here — do not commit a personal URL.
VITE_PUBLIC_API_URL=
