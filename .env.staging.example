# Staging environment configuration
# Copy to .env.staging and fill in the values

# Backend URL for staging
VITE_API_URL=https://api-staging.example.com

# Environment label
VITE_APP_ENV=staging

# Shared LIFF ID — used for PNP link-token greeting flow (LON by Phone)
# Get this from LINE Developers Console → your LIFF app
VITE_SHARED_LIFF_ID=

# Direct backend URL for LIFF public endpoints (bypasses Vite proxy).
# On staging this should point directly at the backend (no proxy needed).
VITE_PUBLIC_API_URL=
